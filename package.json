{
  "private": true,
  "devDependencies": {
    "@discourse/lint-configs": "3.2.0",
    "@glint/ember-tsc": "1.8.12",
    "concurrently": "^9.2.3",
    "discourse": "npm:@discourse/types@2026.3.0-d02b2966",
    "ember-template-lint": "7.9.3",
    "eslint": "10.6.0",
    "lint-to-the-future": "^2.6.4",
    "lint-to-the-future-eslint": "^3.3.0",
    "prettier": "3.8.1",
    "stylelint": "17.5.0"
  },
  "scripts": {
    "lint": "concurrently --names css,js,hbs,prettier,types \"stylelint '{javascripts,desktop,mobile,common,scss,stylesheets}/**/*.scss' --allow-empty-input\" \"eslint {javascripts,test} --cache --no-error-on-unmatched-pattern\" \"ember-template-lint javascripts --no-error-on-unmatched-pattern\" \"prettier '{javascripts,desktop,mobile,common,scss,stylesheets}/**/*.scss' '{javascripts,test}/**/*.{js,gjs,ts,gts,mts,cts}' --check --no-error-on-unmatched-pattern\" \"ember-tsc -b\"",
    "lint:fix": "concurrently --names css,js,hbs,prettier \"stylelint '{javascripts,desktop,mobile,common,scss,stylesheets}/**/*.scss' --fix --allow-empty-input\" \"eslint {javascripts,test} --fix --no-error-on-unmatched-pattern\" \"ember-template-lint javascripts --fix --no-error-on-unmatched-pattern\" \"prettier '{javascripts,desktop,mobile,common,scss,stylesheets}/**/*.scss' '{javascripts,test}/**/*.{js,gjs,ts,gts,mts,cts}' -w --no-error-on-unmatched-pattern\"",
    "lint:css": "stylelint '{javascripts,desktop,mobile,common,scss,stylesheets}/**/*.scss' --allow-empty-input",
    "lint:css:fix": "stylelint '{javascripts,desktop,mobile,common,scss,stylesheets}/**/*.scss' --fix --allow-empty-input",
    "lint:js": "eslint {javascripts,test} --cache --no-error-on-unmatched-pattern",
    "lint:js:fix": "eslint {javascripts,test} --fix --no-error-on-unmatched-pattern",
    "lint:hbs": "ember-template-lint javascripts --no-error-on-unmatched-pattern",
    "lint:hbs:fix": "ember-template-lint javascripts --fix --no-error-on-unmatched-pattern",
    "lint:prettier": "prettier '{javascripts,desktop,mobile,common,scss,stylesheets}/**/*.scss' '{javascripts,test}/**/*.{js,gjs,ts,gts,mts,cts}' --check --no-error-on-unmatched-pattern",
    "lint:prettier:fix": "prettier '{javascripts,desktop,mobile,common,scss,stylesheets}/**/*.scss' '{javascripts,test}/**/*.{js,gjs,ts,gts,mts,cts}' -w --no-error-on-unmatched-pattern",
    "lint:types": "ember-tsc -b",
    "lttf:ignore": "lint-to-the-future ignore"
  },
  "engines": {
    "node": ">=22",
    "npm": "please-use-pnpm",
    "yarn": "please-use-pnpm",
    "pnpm": "^10"
  },
  "packageManager": "pnpm@10.28.0"
}
